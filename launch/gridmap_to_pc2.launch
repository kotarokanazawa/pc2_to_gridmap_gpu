<!-- gridmap_to_pc2.launch -->
<launch>
  <!-- input -->
  <arg name="input_topic"   default="/gazebo/grid_map"/>
  <arg name="output_topic"  default="/grid_map_points"/>
  <arg name="layer"         default="elevation"/>
  <arg name="frame_id"      default="map"/>
  <arg name="queue_size"    default="1"/>

  <node
    pkg="pc2_to_gridmap_gpu"
    type="gridmap_to_pc2_gpu_node"
    name="gridmap_to_pc2_gpu"
    output="screen">

    <param name="input_topic"  value="$(arg input_topic)"/>
    <param name="output_topic" value="$(arg output_topic)"/>
    <param name="layer"        value="$(arg layer)"/>
    <param name="frame_id"     value="$(arg frame_id)"/>
    <param name="queue_size"   value="$(arg queue_size)"/>

  </node>
</launch>
